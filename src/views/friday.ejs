<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <link rel="stylesheet" href="/style.css" />
  <title>Friday</title>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/friday">Friday</a>
    <a href="/tasks">Tasks</a>
  </nav>

  <h1>Friday page</h1>

  <p>Date: <strong><%= dateString %></strong></p>
  <p>Day: <strong><%= weekday %></strong></p>

  <% if (isFriday) { %>
    <div class="friday-crazy">
      🎉 IT'S FRIDAY!!! 🎉<br>
      🚀 CRAZY FRIDAY MODE ACTIVATED 🚀
    </div>
  <% } else { %>
    <p>Not Friday today 😅</p>
  <% } %>

  <p>Test with query string:</p>
  <ul>
    <li><a href="/friday?date=2026-02-27">/friday?date=2026-02-27</a></li>
    <li><a href="/friday?date=2026-02-26">/friday?date=2026-02-26</a></li>
  </ul>
</body>
</html>