<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <link rel="stylesheet" href="/style.css" />
  <title>Task</title>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/tasks">Tasks</a>
  </nav>

  <%- include('../partials/flash') %>

  <h1>Task <%= task.id %></h1>
  <p>Title: <strong><%= task.title %></strong></p>
  <p>Done: <strong><%= task.done ? 'Yes' : 'No' %></strong></p>

  <p>
    <a href="/tasks/<%= task.id %>/edit">Edit</a>
  </p>
</body>
</html>